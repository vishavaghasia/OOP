import java.util.Scanner;

public class VolumeCalculator {

    public double calculateVolume(double side) {
        return Math.pow(side, 3);
    }

    public double calculateVolume(double length, double width, double height) {
        return length * width * height;
    }

    public double calculateVolume(double radius, boolean isSphere) {
        return (4.0 / 3.0) * Math.PI * Math.pow(radius, 3);
    }

    public static void main(String[] args) {
        VolumeCalculator vc = new VolumeCalculator();

        System.out.println("Volume of Cube (side 5): " + vc.calculateVolume(5.0));
        System.out.println("Volume of Rectangular Cube (5x10x2): " + vc.calculateVolume(5.0, 10.0, 2.0));
        System.out.println("Volume of Sphere (radius 3): " + vc.calculateVolume(3.0, true));
    }
}
