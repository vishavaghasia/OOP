import java.util.Scanner;

class BankAccount {
    protected String accountNumber;
    protected String accountHolderName;
    protected double balance;

    public void openAccount() {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter Account Number: ");
        accountNumber = sc.nextLine();
        System.out.print("Enter Account Holder Name: ");
        accountHolderName = sc.nextLine();
        System.out.print("Enter Initial Balance: ");
        balance = sc.nextDouble();
    }

    public void deposit(double amount) {
        balance += amount;
        System.out.println("Deposited: " + amount);
    }

    public void withdraw(double amount) {
        if (balance >= amount) {
            balance -= amount;
            System.out.println("Withdrawn: " + amount);
        } else {
            System.out.println("Insufficient balance.");
        }
    }

    public void checkBalance() {
        System.out.println("Current Balance: " + balance);
    }
}

class SavingAccount extends BankAccount {
    private double interestRate = 0.04;

    public void calculateInterest() {
        double interest = balance * interestRate;
        System.out.println("Interest earned on Savings: " + interest);
    }
}

class FixedDepositAccount extends BankAccount {
    private double interestRate = 0.07;
    private int termYears;

    public void setTerm(int years) {
        this.termYears = years;
    }

    public void maturityAmount() {
        double amount = balance * Math.pow((1 + interestRate), termYears);
        System.out.println("Maturity Amount after " + termYears + " years: " + amount);
    }
}

public class Main {
    public static void main(String[] args) {
        SavingAccount sa = new SavingAccount();
        sa.openAccount();
        sa.deposit(1000);
        sa.calculateInterest();
        sa.checkBalance();

        FixedDepositAccount fda = new FixedDepositAccount();
        fda.openAccount();
        fda.setTerm(5);
        fda.maturityAmount();
    }
}
