import java.util.LinkedList;

public class MusicPlaylist {
    public static void main(String[] args) {
        LinkedList<String> playlist = new LinkedList<>();

        playlist.add("Song A");
        playlist.add("Song B");
        playlist.add("Song C");
        playlist.add("Song D");
        System.out.println("Initial Playlist: " + playlist);

        if (!playlist.isEmpty()) {
            String firstSong = playlist.removeFirst();
            System.out.println("Playing first song: " + firstSong);
            System.out.println("Updated Playlist: " + playlist);
        }

        if (!playlist.isEmpty()) {
            String lastSong = playlist.removeLast();
            System.out.println("Skipping last song: " + lastSong);
            System.out.println("Updated Playlist: " + playlist);
        }
    }
}
