import java.util.LinkedList;

public class GenericSearch {

    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }

    public static void main(String[] args) {
        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);

        System.out.println("Roll Number 102 exists: " + searchElement(rollNumbers, 102));
        System.out.println("Roll Number 105 exists: " + searchElement(rollNumbers, 105));

        LinkedList<String> names = new LinkedList<>();
        names.add("Alice");
        names.add("Bob");
        names.add("Charlie");

        System.out.println("Name 'Alice' exists: " + searchElement(names, "Alice"));
        System.out.println("Name 'David' exists: " + searchElement(names, "David"));
    }
}
